@@ -24111,6 +24117,14 @@
 	char tmp[32];
 	pid_t pid;
 	int i;
+
+	/* Fork GT-BE98 : roamast (assistance de roaming/forced-roaming) desactive par
+	 * defaut sur AP autonome ; le roaming est gere par le webui (802.11v/k). Non
+	 * lance en stock (roamast_disable=1). Ce garde-fou couvre aussi les variantes
+	 * STA_AP_BAND_BIND/FORCE_ROAMING qui ignorent roamast_disable.
+	 * Reactiver : nvram set roamast_enable=1 ; nvram commit. */
+	if (!nvram_get_int("roamast_enable"))
+		return;
 #ifdef RTCONFIG_BCM_MFG
