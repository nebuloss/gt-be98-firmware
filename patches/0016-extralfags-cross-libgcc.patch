--- a/release/src/router/Makefile
+++ b/release/src/router/Makefile
@@ -344,11 +344,14 @@ endif
 
 ifeq ($(HND_ROUTER),y)
 export EXTRA_NV_LDFLAGS := -L$(TOP_PLATFORM)/wlcsm -lwlcsm
-export EXTRALDFLAGS = -lgcc_s
 ifneq ($(GTBE98_TC_ROOT),)
-# Native gt-be98-firmware: crosstool lib/ breaks host gcc (cc1: mpfr_asinpi).
+# Native gt-be98-firmware: no LD_LIBRARY_PATH to crosstool lib/ (cc1: mpfr_asinpi).
+export EXTRALDFLAGS := -Wl,-rpath-link=$(TOOLCHAIN)/arm-buildroot-linux-gnueabi/lib \
+	-L$(TOOLCHAIN)/arm-buildroot-linux-gnueabi/lib \
+	$(TOOLCHAIN)/arm-buildroot-linux-gnueabi/lib/libgcc_s.so
 else
+export EXTRALDFLAGS = -lgcc_s
 export LD_LIBRARY_PATH := $(TOOLCHAIN)/lib
 endif
 export BASEDIR := $(SRCBASE)/../
 
--- a/release/src/router/Makefile
+++ b/release/src/router/Makefile
@@ -7881,9 +7885,19 @@ pcre-8.12-clean:
 
 pcre-8.31/stamp-h1:
 	cd pcre-8.31 && \
-	CC=$(CC) CXX=$(CXX) AR=$(AR) RANLIB=$(RANLIB) LD=$(LD) CFLAGS="-Os -Wall $(EXTRACFLAGS)" LIBS="$(EXTRALDFLAGS)" \
+	CC=$(CC) CXX=$(CXX) AR=$(AR) RANLIB=$(RANLIB) LD=$(LD) \
+	CFLAGS="-Os -Wall $(EXTRACFLAGS)" \
+	LDFLAGS="$(EXTRALDFLAGS)" LIBS="$(EXTRALDFLAGS)" \
 	./$(CONFIGURE) --prefix=/usr --disable-dependency-tracking
 	touch $@
 	[ -d pcre-8.31/m4 ] || mkdir pcre-8.31/m4
 
 pcre-8.31: pcre-8.31/stamp-h1
+	@if [ ! -f pcre-8.31/.libs/libpcre.so.1.0.1 ]; then \
+		echo "gt-be98: pcre .libs missing (stale libtool state), clean+rebuild"; \
+		$(MAKE) -C pcre-8.31 clean; \
+	fi
+	$(MAKE) -C pcre-8.31
+	@[ -f pcre-8.31/.libs/libpcre.so.1.0.1 ] || \
+		(echo "pcre-8.31: libpcre.so.1.0.1 not built" >&2; exit 1)
+	$(MAKE) $@-stage
