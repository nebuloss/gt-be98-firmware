--- /dev/null
+++ b/release/src/router/portmap/tirpc_compat.h
@@ -0,0 +1,46 @@
+/*
+ * Map libtirpc sockaddr_in6 callers to legacy portmap sockaddr_in API.
+ */
+#ifndef PORTMAP_TIRPC_COMPAT_H
+#define PORTMAP_TIRPC_COMPAT_H
+
+#include <string.h>
+#include <netinet/in.h>
+#include <arpa/inet.h>
+#include <rpc/svc.h>
+
+static inline struct sockaddr_in *caller_sockaddr_in(SVCXPRT *xprt)
+{
+	static struct sockaddr_in sin4;
+	struct sockaddr *sa = svc_getcaller(xprt);
+
+	if (sa->sa_family == AF_INET)
+		return (struct sockaddr_in *)sa;
+
+	memset(&sin4, 0, sizeof(sin4));
+	sin4.sin_family = AF_INET;
+
+	if (sa->sa_family == AF_INET6) {
+		const struct sockaddr_in6 *sin6 = (const struct sockaddr_in6 *)sa;
+
+		sin4.sin_port = sin6->sin6_port;
+		if (IN6_IS_ADDR_V4MAPPED(&sin6->sin6_addr))
+			memcpy(&sin4.sin_addr, &sin6->sin6_addr.s6_addr[12], 4);
+		else if (IN6_IS_ADDR_LOOPBACK(&sin6->sin6_addr))
+			sin4.sin_addr.s_addr = htonl(INADDR_LOOPBACK);
+	}
+	return &sin4;
+}
+
+static inline in_port_t caller_sin_port(SVCXPRT *xprt)
+{
+	struct sockaddr *sa = svc_getcaller(xprt);
+
+	if (sa->sa_family == AF_INET)
+		return ((struct sockaddr_in *)sa)->sin_port;
+	if (sa->sa_family == AF_INET6)
+		return ((struct sockaddr_in6 *)sa)->sin6_port;
+	return 0;
+}
+
+#endif /* PORTMAP_TIRPC_COMPAT_H */
